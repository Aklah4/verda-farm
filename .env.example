# Copy to .env and fill in. Never commit the real .env.
# Generate a key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# development | production  (production refuses to boot on the default key)
VERDA_ENV=development

VERDA_ACCENT=#2E7D4E
VERDA_HERO=split
VERDA_WHATSAPP=1

# MongoDB Atlas. The full driver string from Atlas (Connect -> Drivers -> Python),
# with <db_password> replaced by the real password. No quotes. A password holding
# @ / : or ? must be percent-encoded (@ -> %40, / -> %2F) or the URI will not parse.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/?appName=<app>
MONGO_DB=verda

# The superadmin login and the Cloudinary API key live in .env only, not here.
# A fresh deploy still needs them, so for the record they are:
#
#   ADMIN_USERNAME / ADMIN_PASSWORD / ADMIN_FIRST_NAME / ADMIN_LAST_NAME
#       The staff account for /admin/login. `flask seed-admin` creates it.
#
#   CLOUDINARY_URL / MAX_UPLOAD_MB
#       Product image hosting. Without it, uploads are disabled and the
#       storefront falls back to colour swatches; nothing else breaks.
